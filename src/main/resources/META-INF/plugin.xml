<!-- Plugin Configuration File. Read more: https://plugins.jetbrains.com/docs/intellij/plugin-configuration-file.html -->
<idea-plugin>
    <id>com.aiassistant.testgenerator</id>

    <name>AI Test Generator</name>

<vendor email="support@aitestgenerator.com"
        url="https://github.com/yourrepo">

Kanu Priya
</vendor>

    <idea-version since-build="231" until-build="251.*"/>
<description>
<![CDATA[
        AI Test Generator helps QA engineers generate Playwright automation tests directly from Excel test case sheets.

        Features:
        • Upload Excel test cases
        • AI-generated Playwright test methods
        • Page Object style generation
        • Insert generated code directly into editor
        ]]>
</description>
    <change-notes>
        <![CDATA[
        Version 1.0
        • Excel based AI test generation
        • Playwright Java test generation
        • IntelliJ tool window integration
        ]]>
    </change-notes>

    <depends>com.intellij.modules.platform</depends>

    <resource-bundle>messages.MyBundle</resource-bundle>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow factoryClass="org.jetbrains.plugins.template.toolWindow.MyToolWindowFactory" id="MyToolWindow"/>
        <postStartupActivity implementation="org.jetbrains.plugins.template.startup.MyProjectActivity" />
        <toolWindow
                id="AI Test Generator"
                anchor="right"
                icon="/icons/aiToolWindow.svg"
                factoryClass="com.aiassistant.toolwindow.AITestGeneratorToolWindowFactory"/>


    </extensions>
    <actions>


            <action id="GenerateTestAction"
                    class="com.aiassistant.actions.GenerateTestAction"
                    text="Generate Test From Excel"
                    description="Generate test code">

                <add-to-group group-id="EditorPopupMenu" anchor="last"/>

            </action>
        <action id="GenerateTestFromSelection"
                class="com.aiassistant.actions.GenerateTestAction"
                text="Generate Playwright Test from Selection"
                description="Generate Playwright test using AI from selected text"
                icon="/icons/generateTest.svg">
<!--                icon="resources/resourcesicons/">-->
            <add-to-group group-id="EditorPopupMenu" anchor="last"/>
        </action>

    </actions>
</idea-plugin>
